---
/* 《琵琶行》背诵图卡 · 三态句卡（图 → 首字 → 全句）
   配图随背诵进度分批补充：public/images/pipa-xing/<句号>.webp 放进去即自动上卡。 */
import fs from 'node:fs';
import Base from '../../layouts/Base.astro';
import { withBase } from '../../scripts/url';

const LINES = [
  '浔阳江头夜送客，', '枫叶荻花秋瑟瑟。', '主人下马客在船，', '举酒欲饮无管弦。',
  '醉不成欢惨将别，', '别时茫茫江浸月。', '忽闻水上琵琶声，', '主人忘归客不发。',
  '寻声暗问弹者谁，', '琵琶声停欲语迟。', '移船相近邀相见，', '添酒回灯重开宴。',
  '千呼万唤始出来，', '犹抱琵琶半遮面。', '转轴拨弦三两声，', '未成曲调先有情。',
  '弦弦掩抑声声思，', '似诉平生不得志。', '低眉信手续续弹，', '说尽心中无限事。',
  '轻拢慢捻抹复挑，', '初为《霓裳》后《六幺》。', '大弦嘈嘈如急雨，', '小弦切切如私语。',
  '嘈嘈切切错杂弹，', '大珠小珠落玉盘。', '间关莺语花底滑，', '幽咽泉流冰下难。',
  '冰泉冷涩弦凝绝，', '凝绝不通声暂歇。', '别有幽愁暗恨生，', '此时无声胜有声。',
  '银瓶乍破水浆迸，', '铁骑突出刀枪鸣。', '曲终收拨当心画，', '四弦一声如裂帛。',
  '东船西舫悄无言，', '唯见江心秋月白。', '沉吟放拨插弦中，', '整顿衣裳起敛容。',
  '自言本是京城女，', '家在虾蟆陵下住。', '十三学得琵琶成，', '名属教坊第一部。',
  '曲罢曾教善才服，', '妆成每被秋娘妒。', '五陵年少争缠头，', '一曲红绡不知数。',
  '钿头银篦击节碎，', '血色罗裙翻酒污。', '今年欢笑复明年，', '秋月春风等闲度。',
  '弟走从军阿姨死，', '暮去朝来颜色故。', '门前冷落鞍马稀，', '老大嫁作商人妇。',
  '商人重利轻别离，', '前月浮梁买茶去。', '去来江口守空船，', '绕船月明江水寒。',
  '夜深忽梦少年事，', '梦啼妆泪红阑干。', '我闻琵琶已叹息，', '又闻此语重唧唧。',
  '同是天涯沦落人，', '相逢何必曾相识！', '我从去年辞帝京，', '谪居卧病浔阳城。',
  '浔阳地僻无音乐，', '终岁不闻丝竹声。', '住近湓江地低湿，', '黄芦苦竹绕宅生。',
  '其间旦暮闻何物？', '杜鹃啼血猿哀鸣。', '春江花朝秋月夜，', '往往取酒还独倾。',
  '岂无山歌与村笛？', '呕哑嘲哳难为听。', '今夜闻君琵琶语，', '如听仙乐耳暂明。',
  '莫辞更坐弹一曲，', '为君翻作《琵琶行》。', '感我此言良久立，', '却坐促弦弦转急。',
  '凄凄不似向前声，', '满座重闻皆掩泣。', '座中泣下谁最多？', '江州司马青衫湿。',
];

const SCENES = [
  { no: 1, name: '秋江夜别', anchor: '江浸月', from: 1, to: 6 },
  { no: 2, name: '水上琵琶', anchor: '半遮面', from: 7, to: 14 },
  { no: 3, name: '一曲琵琶', anchor: '珠落玉盘', from: 15, to: 38 },
  { no: 4, name: '自诉身世', anchor: '血色罗裙', from: 39, to: 62 },
  { no: 5, name: '同是沦落', anchor: '杜鹃啼血', from: 63, to: 82 },
  { no: 6, name: '重弹泣下', anchor: '青衫湿', from: 83, to: 88 },
];

// 已配图的句号：目录里有 NN.webp 就算
const imgDir = new URL('../../../public/images/pipa-xing/', import.meta.url);
const avail = new Set(
  fs.readdirSync(imgDir).filter((f) => f.endsWith('.webp')).map((f) => Number.parseInt(f, 10))
);
const availCount = avail.size;
const pad = (n: number) => String(n).padStart(2, '0');
---

<Base title="《琵琶行》背诵图卡 · 图像记忆" active="recite">
  <article class="recite-page" data-recite="pipa-xing">
    <h1>《琵琶行》背诵图卡</h1>
    <div class="lesson-meta">
      白居易 · 六幕 · 88 句 · 已配图 {availCount}/88（随背诵进度补批）
      · 方法见 <a href={withBase('/lessons/0009-verbatim-text')}>第 9 课</a>
    </div>

    <p>
      每张卡是一句诗的<strong>记忆画面</strong>。用法是第 9 课的递减提示：先凭画面默背整句，
      卡壳了点一下卡露出<strong>首字</strong>，再点才是<strong>全句</strong>（再点一下重新遮住）。
      翻卡不算练习——每幕能<strong>白板背下来</strong>了，在幕尾给自己盖章，那才记一天。
    </p>

    <div class="toolbar">
      <button class="reveal-all" type="button">全部揭示</button>
    </div>

    {SCENES.map((sc) => {
      const nums = Array.from({ length: sc.to - sc.from + 1 }, (_, i) => sc.from + i);
      const have = nums.filter((n) => avail.has(n));
      return (
        <section class="scene">
          <h2>
            第{['一', '二', '三', '四', '五', '六'][sc.no - 1]}幕 · {sc.name}
            <span class="anchor-hint">锚画面「{sc.anchor}」</span>
          </h2>
          {have.length > 0 ? (
            <div class="card-grid">
              {have.map((n) => (
                <figure class="verse-card" data-state="0" tabindex="0" role="button" aria-label={`第 ${n} 句句卡，点击翻面`}>
                  <img src={withBase(`/images/pipa-xing/${pad(n)}.webp`)} alt={`第 ${n} 句配图`} width="1344" height="768" loading="lazy" />
                  <figcaption class="line">
                    <span class="line-no">{n}</span>
                    <span class="line-hint">· · ·</span>
                    <span class="line-first">{LINES[n - 1][0]} ——</span>
                    <span class="line-full">{LINES[n - 1]}</span>
                  </figcaption>
                </figure>
              ))}
            </div>
          ) : null}
          {have.length < nums.length ? (
            <p class="pending">本幕已配 {have.length}/{nums.length} 句，其余随背诵进度补上。</p>
          ) : null}
          <button class="scene-stamp" type="button" data-scene={String(sc.no)}>
            <span class="seal">记</span>
            <span class="stamp-text">这幕白板背过了 · 盖章</span>
          </button>
        </section>
      );
    })}

    <nav class="lesson-nav">
      <a href={withBase('/lessons/0009-verbatim-text')}>← 第 9 课：逐字背诵</a> ·
      <a href={withBase('/')}>返回路线</a>
      <br /><br />哪一句的画面钉不牢？直接问我——我们当场返工那张卡。
    </nav>
  </article>
</Base>

<style>
  .recite-page h1 {
    margin-bottom: 0.3rem;
  }
  .toolbar {
    margin: 1rem 0 0.4rem;
  }
  .reveal-all {
    font: inherit;
    font-size: 0.88rem;
    padding: 0.35rem 0.9rem;
    border: 1px solid var(--rule);
    border-radius: 999px;
    background: var(--card);
    color: var(--ink-soft);
    cursor: pointer;
  }
  .reveal-all:hover {
    color: var(--dusk-strong);
    border-color: var(--dusk);
  }
  .scene {
    margin: 2rem 0 2.4rem;
  }
  .scene h2 {
    display: flex;
    align-items: baseline;
    gap: 0.7rem;
    flex-wrap: wrap;
  }
  .anchor-hint {
    font-size: 0.8rem;
    font-weight: normal;
    color: var(--amber);
  }
  .card-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(270px, 1fr));
    gap: 1rem;
    margin-top: 0.8rem;
  }
  .verse-card {
    margin: 0;
    background: var(--card);
    border: 1px solid var(--rule);
    border-radius: 10px;
    overflow: hidden;
    box-shadow: var(--shadow);
    cursor: pointer;
    user-select: none;
  }
  .verse-card img {
    display: block;
    width: 100%;
    height: auto;
  }
  .verse-card .line {
    display: flex;
    align-items: baseline;
    gap: 0.55rem;
    padding: 0.55rem 0.8rem 0.65rem;
    font-family: var(--serif);
    font-size: 1.02rem;
    min-height: 2.2rem;
  }
  .line-no {
    font-family: var(--num);
    font-size: 0.72rem;
    color: var(--ink-soft);
  }
  .line-hint {
    color: var(--ink-soft);
    letter-spacing: 0.3em;
  }
  .line-first {
    display: none;
    color: var(--dusk-strong);
  }
  .line-full {
    display: none;
    color: var(--ink);
  }
  .verse-card[data-state='1'] .line-hint { display: none; }
  .verse-card[data-state='1'] .line-first { display: inline; }
  .verse-card[data-state='2'] .line-hint { display: none; }
  .verse-card[data-state='2'] .line-full { display: inline; }
  .pending {
    font-size: 0.85rem;
    color: var(--ink-soft);
    margin: 0.7rem 0 0;
  }
  .scene-stamp {
    display: inline-flex;
    align-items: center;
    gap: 0.55rem;
    margin-top: 0.9rem;
    font: inherit;
    font-size: 0.9rem;
    padding: 0.4rem 0.95rem 0.4rem 0.5rem;
    border: 1px dashed var(--rule);
    border-radius: 8px;
    background: transparent;
    color: var(--ink-soft);
    cursor: pointer;
  }
  .scene-stamp .seal {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 1.7rem;
    height: 1.7rem;
    border-radius: 6px;
    border: 1.5px solid currentColor;
    font-family: var(--serif);
    color: var(--ink-soft);
    opacity: 0.55;
  }
  .scene-stamp.stamped {
    border-style: solid;
    border-color: var(--cinnabar);
    color: var(--cinnabar);
    background: var(--cinnabar-soft);
  }
  .scene-stamp.stamped .seal {
    color: var(--cinnabar);
    opacity: 1;
  }
</style>

<script>
  import { logPracticeDay } from '../../scripts/progress';

  const KEY = 'rbi:v1:recite:pipa-xing';

  interface ReciteState {
    scenes?: Record<string, { at: string }>;
  }

  function load(): ReciteState {
    try {
      return JSON.parse(localStorage.getItem(KEY) || '{}');
    } catch {
      return {};
    }
  }

  // 三态句卡：0 只图 → 1 首字 → 2 全句 → 回到 0
  const cards = [...document.querySelectorAll<HTMLElement>('.verse-card')];
  for (const card of cards) {
    const flip = () => {
      card.dataset.state = String((Number(card.dataset.state || '0') + 1) % 3);
    };
    card.addEventListener('click', flip);
    card.addEventListener('keydown', (e) => {
      if (e.key === 'Enter' || e.key === ' ') {
        e.preventDefault();
        flip();
      }
    });
  }

  // 全部揭示 / 全部遮住
  const revealBtn = document.querySelector<HTMLButtonElement>('.reveal-all');
  revealBtn?.addEventListener('click', () => {
    const anyHidden = cards.some((c) => c.dataset.state !== '2');
    for (const c of cards) c.dataset.state = anyHidden ? '2' : '0';
    revealBtn.textContent = anyHidden ? '全部遮住' : '全部揭示';
  });

  // 每幕自评章：点章才算练习（记练习日）；可重复盖，日期更新
  const fmtDate = (iso: string) => iso.slice(0, 10);
  const stamps = [...document.querySelectorAll<HTMLButtonElement>('.scene-stamp')];
  const state = load();
  for (const btn of stamps) {
    const no = btn.dataset.scene!;
    const done = state.scenes?.[no];
    if (done) {
      btn.classList.add('stamped');
      btn.querySelector('.stamp-text')!.textContent = `白板背过 · ${fmtDate(done.at)}（再盖更新）`;
    }
    btn.addEventListener('click', () => {
      const s = load();
      s.scenes = s.scenes || {};
      s.scenes[no] = { at: new Date().toISOString() };
      localStorage.setItem(KEY, JSON.stringify(s));
      logPracticeDay();
      btn.classList.add('stamped');
      btn.querySelector('.stamp-text')!.textContent = `白板背过 · ${fmtDate(s.scenes[no].at)}（再盖更新）`;
    });
  }
</script>
