---
/* 回忆默写测试：凭记忆按顺序（或乱序）默写一组词。
   检查后即时反馈，并把成绩记入本课进度（localStorage）。 */
interface Props {
  items: string[];
  ordered?: boolean;
  placeholder?: string;
}

const { items, ordered = true, placeholder = '第 {n} 个' } = Astro.props;
---

<recall-test class="recall-test" data-items={JSON.stringify(items)} data-ordered={ordered ? '1' : ''}>
  <div class="recall-inputs">
    {items.map((_, i) => (
      <input type="text" autocomplete="off" placeholder={placeholder.replace('{n}', String(i + 1))} />
    ))}
  </div>
  <button class="check" type="button">检查答案</button>
  <div class="result" role="status"></div>
</recall-test>

<script>
  import { recordRecall } from '../scripts/progress';

  const norm = (s: string) => (s || '').trim().replace(/\s+/g, '');

  class RecallTest extends HTMLElement {
    connectedCallback() {
      const items: string[] = JSON.parse(this.dataset.items || '[]');
      const ordered = this.dataset.ordered === '1';
      const inputs = [...this.querySelectorAll<HTMLInputElement>('input')];
      const result = this.querySelector<HTMLElement>('.result')!;

      this.querySelector('.check')?.addEventListener('click', () => {
        let correct = 0;
        if (ordered) {
          inputs.forEach((input, i) => {
            const hit = norm(input.value) === norm(items[i]);
            input.classList.toggle('ok', hit);
            input.classList.toggle('err', !hit);
            if (hit) correct++;
          });
        } else {
          const remaining = items.map(norm);
          inputs.forEach((input) => {
            const v = norm(input.value);
            const idx = remaining.indexOf(v);
            const hit = v !== '' && idx !== -1;
            if (hit) remaining.splice(idx, 1);
            input.classList.toggle('ok', hit);
            input.classList.toggle('err', !hit);
            if (hit) correct++;
          });
        }

        result.className = 'result show ' + (correct === items.length ? 'good' : 'bad');
        result.textContent =
          correct === items.length
            ? `全对！${correct}/${items.length} —— 图像链条完整地留在了你的脑子里。`
            : `答对 ${correct}/${items.length}。回到故事里：卡住的地方，往往是图像不够夸张、不够动态的地方。把那一环改造得更荒诞，再试一次。`;

        const slug = this.closest<HTMLElement>('[data-lesson]')?.dataset.lesson;
        if (slug) recordRecall(slug, correct, items.length);
      });
    }
  }

  customElements.define('recall-test', RecallTest);
</script>
